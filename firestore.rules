rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // User Profile Rules
    // ===============================================================

    function isValidUserProfile(data) {
      let allowedFields = ['uid', 'displayName', 'email', 'photoURL', 'createdAt', 'updatedAt'];
      return data.keys().hasAll(['uid', 'email']) &&
             data.keys().hasOnly(allowedFields) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             (data.get('displayName', null) == null || (data.displayName is string && data.displayName.size() <= 256)) &&
             (data.get('photoURL', null) == null || (data.photoURL is string && data.photoURL.size() <= 800000)) &&
             (data.get('createdAt', null) == null || data.createdAt is timestamp) &&
             (data.get('updatedAt', null) == null || data.updatedAt is timestamp);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      
      allow create: if isOwner(userId) && 
                      isValidUserProfile(incoming()) && 
                      incoming().createdAt == request.time;
      
      allow update: if isOwner(userId) && 
                      isValidUserProfile(incoming()) && 
                      incoming().uid == existing().uid &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time;

      // ===============================================================
      // Travel Plan Rules
      // ===============================================================

      function isValidTravelPlan(data) {
        let requiredFields = [
          'uid', 'destination', 'duration', 'mood', 'travelerType', 
          'travelerCount', 'summary', 'currencyCode', 'itinerary', 
          'recommendedHotels', 'packingList', 'tips', 'estimatedBudget', 'createdAt'
        ];
        let allowedFields = requiredFields.concat([
          'heroImage', 'isBudgetValid', 'minimumBudget', 'tourNavigator', 'activitiesPerDay'
        ]);
        
        return data.keys().hasAll(requiredFields) &&
               data.keys().hasOnly(allowedFields) &&
               data.uid == request.auth.uid &&
               data.destination is string && data.destination.size() <= 256 &&
               data.duration is number &&
               data.itinerary is list &&
               data.recommendedHotels is list &&
               data.estimatedBudget is list &&
               data.createdAt is timestamp;
      }

      match /plans/{planId} {
        allow read: if isOwner(userId);
        
        allow create: if isOwner(userId) && 
                        isValidTravelPlan(incoming()) && 
                        incoming().createdAt == request.time;
        
        allow update: if isOwner(userId) && 
                        isValidTravelPlan(incoming()) && 
                        incoming().uid == existing().uid &&
                        incoming().createdAt == existing().createdAt;
                        
        allow delete: if isOwner(userId);
      }
    }
  }
}
